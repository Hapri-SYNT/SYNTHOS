"""
gguf_knowledge_exporter.py
==========================
GGUF Model Knowledge Graph Exporter with Integrated Parser + Remote Reader

Features:
  • Local GGUF parsing (multi-part, mmap, magic scan)
  • Remote GGUF header fetching from HuggingFace (HTTP Range)
  • Epistemic knowledge graph generation (9 categories)
  • Causal RoPE analysis
  • Risk assessment nodes
  • JSON export

Usage:
  # Local file
  python gguf_knowledge_exporter.py model.gguf -o local_brain.json

  # Remote HuggingFace URL
  python gguf_knowledge_exporter.py https://huggingface.co/.../model.gguf -o remote_brain.json

  # With HF token for private models
  python gguf_knowledge_exporter.py https://... --hf-token hf_xxxxx -o output.json
"""

from __future__ import annotations

import json
import math
import mmap
import os
import re
import struct
import warnings
import hashlib
import time
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any, Callable, Dict, List, Optional, Tuple, Union
import sys

# ===========================================================================
# UTILITIES
# ===========================================================================

def _fmt_bytes(n: int) -> str:
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if n < 1024 or unit == "TB":
            return f"{n:.2f} {unit}"
        n /= 1024


# ===========================================================================
# BINARY READER (mmap-aware)
# ===========================================================================

class BinaryReader:
    GGUF_MAGIC = b"GGUF"

    def __init__(self, data: Union[bytes, mmap.mmap], little_endian: bool = True, base_offset: int = 0):
        self._data = data
        self._little_endian = little_endian
        self._position = base_offset
        self._base = base_offset
        self._length = len(data)

    @property
    def position(self) -> int:
        return self._position

    @property
    def remaining(self) -> int:
        return self._length - self._position

    def seek(self, position: int) -> None:
        if not (0 <= position <= self._length):
            raise EOFError(f"Seek out of bounds: {position} / {self._length}")
        self._position = position

    def skip(self, count: int) -> None:
        self._position += count
        if self._position > self._length:
            raise EOFError("Unexpected end of data")

    def read(self, length: int) -> bytes:
        end = self._position + length
        if end > self._length:
            raise EOFError(f"Read {length} bytes overflows buffer")
        chunk = self._data[self._position:end]
        self._position = end
        return bytes(chunk)

    @classmethod
    def find_magic_offset(cls, data: Union[bytes, mmap.mmap]) -> int:
        idx = data.find(cls.GGUF_MAGIC)
        if idx == -1:
            raise ValueError("GGUF magic b'GGUF' not found in data")
        if idx > 0:
            warnings.warn(f"GGUF magic found at offset {idx} (not at byte 0)", RuntimeWarning)
        return idx

    def uint32(self) -> int:
        fmt = "<I" if self._little_endian else ">I"
        return struct.unpack(fmt, self.read(4))[0]

    def uint64(self) -> int:
        fmt = "<Q" if self._little_endian else ">Q"
        return struct.unpack(fmt, self.read(8))[0]

    def string(self) -> str:
        length = self.uint64()
        if length == 0 or length > 10_000_000:
            return ""
        return self.read(length).decode("utf-8", errors="replace")

    def entry(self) -> Dict:
        name = self.string()
        gguf_type = self.uint32()
        if gguf_type == 8:
            val = self.string()
        elif gguf_type == 4:
            val = self.uint32()
        elif gguf_type == 5:
            val = self.uint32()
        elif gguf_type == 6:
            fmt = "<f" if self._little_endian else ">f"
            val = struct.unpack(fmt, self.read(4))[0]
        elif gguf_type == 10:
            val = self.uint64()
        elif gguf_type == 11:
            val = self.uint64()
        elif gguf_type == 9:
            item_type = self.uint32()
            count = self.uint64()
            if count > 10_000_000:
                val = []
            elif item_type == 8:
                val = [self.string() for _ in range(count)]
            else:
                val = [0 for _ in range(count)]
        else:
            val = None
        return {"name": name, "value": val, "type": gguf_type}

    def tensor_info(self) -> Dict:
        name = self.string()
        n_dims = self.uint32()
        dims = [self.uint64() for _ in range(n_dims)]
        qtype = self.uint32()
        offset = self.uint64()
        return {"name": name, "dimensions": dims, "quant_type": qtype, "offset": offset}

    def align_to(self, alignment: int) -> None:
        remainder = self._position % alignment
        if remainder:
            self.skip(alignment - remainder)


