"""
TransformerLens Adapter - 6 Modul Lengkap (100% intisari)
Diadaptasi dari TransformerLens untuk QND DeepReader

Modul:
1. Hook Points - Mekanisme penyisipan hook
2. ActivationCache - Penyimpanan & analisis aktivasi
3. SVDInterpreter - Dekomposisi matriks weights
4. Head Detector - Deteksi attention head spesialis
5. Logit Lens - Prediksi token per layer
6. HookedTransformer - Struktur dasar model yang di-hook
"""

import numpy as np
from typing import Dict, List, Tuple, Optional, Callable, Union, Any
from collections import defaultdict
import warnings


# =============================================================================
# MODUL 1: HOOK POINTS (dari hook_points.py)
# =============================================================================

class HookPoint:
    """
    Titik penyisipan hook di dalam model.
    Porting dari transformer_lens.hook_points.HookPoint.
    
    HookPoint adalah modul dummy yang bertindak sebagai identity function.
    Dengan membungkus aktivasi intermediate dalam HookPoint, kita bisa
    menambahkan hook untuk menginspeksi atau mengubah aktivasi.
    """
    
    def __init__(self, name: str = None):
        self.name = name
        self.fwd_hooks: List[Callable] = []
        self.bwd_hooks: List[Callable] = []
        self.ctx: Dict = {}
        self.hook_conversion = None
    
    def add_hook(self, hook: Callable, dir: str = "fwd", is_permanent: bool = False):
        """
        Tambahkan hook ke HookPoint.
        
        Args:
            hook: Fungsi dengan signature fn(activation, hook_name) -> Optional[modified_activation]
            dir: "fwd" untuk forward pass, "bwd" untuk backward pass
            is_permanent: Jika True, hook tidak akan dihapus setelah pemakaian
        """
        if dir == "fwd":
            self.fwd_hooks.append({"hook": hook, "permanent": is_permanent})
        elif dir == "bwd":
            self.bwd_hooks.append({"hook": hook, "permanent": is_permanent})
    
    def remove_hooks(self, dir: str = "fwd", including_permanent: bool = False):
        """Hapus hook dari HookPoint."""
        if dir == "fwd":
            if including_permanent:
                self.fwd_hooks = []
            else:
                self.fwd_hooks = [h for h in self.fwd_hooks if h["permanent"]]
        elif dir == "bwd":
            if including_permanent:
                self.bwd_hooks = []
            else:
                self.bwd_hooks = [h for h in self.bwd_hooks if h["permanent"]]
    
    def clear_context(self):
        """Bersihkan konteks hook."""
        self.ctx = {}
    
    def forward(self, x: np.ndarray) -> np.ndarray:
        """
        Forward pass dengan hooks.
        Setiap hook dipanggil secara berurutan. Jika hook mengembalikan nilai,
        nilai tersebut menggantikan aktivasi untuk hook berikutnya.
        """
        output = x
        for hook_info in self.fwd_hooks:
            result = hook_info["hook"](output, hook=self)
            if result is not None:
                output = result
        return output
    
    def layer(self) -> int:
        """Ekstrak indeks layer dari nama hook (format: blocks.{layer}.{...})"""
        if self.name is None:
            raise ValueError("HookPoint name is None")
        parts = self.name.split(".")
        if len(parts) >= 2 and parts[0] == "blocks":
            return int(parts[1])
        raise ValueError(f"Cannot extract layer from name: {self.name}")


class HookedRootModule:
    """
    Modul root yang mendukung HookPoints.
    Porting dari transformer_lens.hook_points.HookedRootModule.
    
    Menyediakan utilitas untuk menjalankan model dengan hooks sementara,
    dan menjalankan model dengan cache untuk menyimpan semua aktivasi.
    """
    
    def __init__(self):
        self.mod_dict: Dict[str, Any] = {}
        self.hook_dict: Dict[str, HookPoint] = {}
        self.is_caching = False
        self.context_level = 0
    
    def setup(self):
        """
        Setup modul setelah semua layer didefinisikan.
        Membangun dictionary modul dan hook.
        """
        # Dalam implementasi nyata, ini akan traverse semua submodul
        # Untuk adaptasi QND, kita akan setup manual
        pass
    
    def hook_points(self):
        """Return semua HookPoints dalam model."""
        return self.hook_dict.values()
    
    def remove_all_hook_fns(self, direction: str = "both", including_permanent: bool = False):
        """Hapus semua fungsi hook dari semua HookPoints."""
        for hp in self.hook_points():
            if direction in ("fwd", "both"):
                hp.remove_hooks("fwd", including_permanent)
            if direction in ("bwd", "both"):
                hp.remove_hooks("bwd", including_permanent)
    
    def clear_contexts(self):
        """Bersihkan konteks semua HookPoints."""
        for hp in self.hook_points():
            hp.clear_context()
    
    def reset_hooks(self, clear_contexts: bool = True, direction: str = "both"):
        """Reset semua hooks ke keadaan awal."""
        if clear_contexts:
            self.clear_contexts()
        self.remove_all_hook_fns(direction)
        self.is_caching = False
    
    def add_hook(self, name: Union[str, Callable], hook: Callable, dir: str = "fwd"):
        """Tambahkan hook ke HookPoint tertentu atau ke semua yang cocok dengan filter."""
        if isinstance(name, str):
            if name in self.mod_dict:
                hp = self.mod_dict[name]
                if isinstance(hp, HookPoint):
                    hp.add_hook(hook, dir=dir)
        elif callable(name):
            # name adalah fungsi filter
            for hook_name, hp in self.hook_dict.items():
                if name(hook_name):
                    hp.add_hook(hook, dir=dir)
    
    def run_with_cache(
        self,
        *model_args,
        names_filter: Union[None, str, List[str], Callable] = None,
        remove_batch_dim: bool = False,
        **model_kwargs
    ) -> Tuple[Any, Dict[str, np.ndarray]]:
        """
        Jalankan model dan kembalikan output + cache semua aktivasi.
        Porting dari HookedRootModule.run_with_cache.
        
        Returns:
            (model_output, cache_dict)
        """
        cache = {}
        
        # Setup filter nama
        if names_filter is None:
            filter_fn = lambda name: True
        elif isinstance(names_filter, str):
            filter_fn = lambda name, s=names_filter: name == s
        elif isinstance(names_filter, list):
            filter_fn = lambda name, lst=names_filter: name in lst
        else:
            filter_fn = names_filter
        
        # Tambahkan caching hooks
        for name, hp in self.hook_dict.items():
            if filter_fn(name):
                def make_cache_hook(hook_name):
                    def cache_hook(tensor, hook):
                        cached = tensor.copy()
                        if remove_batch_dim:
                            cached = cached[0]
                        cache[hook_name] = cached
                        return None  # Tidak mengubah aktivasi
                    return cache_hook
                hp.add_hook(make_cache_hook(name), dir="fwd")
        
        # Jalankan model
        output = self.forward(*model_args, **model_kwargs)
        
        # Reset hooks
        self.reset_hooks()
        
        return output, cache


# =============================================================================
# MODUL 2: ACTIVATION CACHE (dari ActivationCache.py)
# =============================================================================

class ActivationCache:
    """
    Cache untuk menyimpan dan menganalisis aktivasi model.
    Porting dari transformer_lens.ActivationCache.
    
    Menyediakan metode untuk:
    - decompose_resid: Memisahkan residual stream per komponen
    - accumulated_resid: Akumulasi residual stream per layer (Logit Lens)
    - logit_attrs: Atribusi logit ke komponen
    - get_full_resid_decomposition: Dekomposisi penuh termasuk neuron MLP
    """
    
    def __init__(self, cache: Dict[str, np.ndarray], model: Any = None):
        """
        Args:
            cache: Dictionary aktivasi dari run_with_cache
            model: Referensi ke model (opsional)
        """
        self._cache = cache
        self.model = model
        self._analyze_structure()
    
    def _analyze_structure(self):
        """Analisis struktur cache untuk menentukan layer yang tersedia."""
        self.layers = set()
        for key in self._cache:
            # Coba ekstrak nomor layer dari nama hook
            parts = key.split(".")
            for i, part in enumerate(parts):
                if part.isdigit():
                    self.layers.add(int(part))
        
        self.n_layers = max(self.layers) + 1 if self.layers else 0
        
        # Deteksi komponen yang tersedia
        self.has_embed = "hook_embed" in self._cache
        self.has_pos_embed = "hook_pos_embed" in self._cache
    
    def __getitem__(self, key: Union[str, Tuple[str, int]]) -> np.ndarray:
        """Akses cache dengan key atau (key, layer)."""
        if isinstance(key, tuple):
            name, layer = key
            return self._cache.get(f"blocks.{layer}.{name}")
        return self._cache.get(key)
    
    def __contains__(self, key: str) -> bool:
        return key in self._cache
    
    def keys(self):
        """Return semua kunci cache."""
        return self._cache.keys()
    
    def values(self):
        """Return semua nilai cache."""
        return self._cache.values()
    
    def items(self):
        """Return semua pasangan (kunci, nilai) cache."""
        return self._cache.items()
    
    def decompose_resid(
        self,
        layer: int = None,
        mode: str = "all",
        apply_ln: bool = False,
        incl_embeds: bool = True,
        return_labels: bool = False
    ) -> Union[np.ndarray, Tuple[np.ndarray, List[str]]]:
        """
        Dekomposisi residual stream menjadi kontribusi per komponen.
        Porting dari ActivationCache.decompose_resid.
        
        Args:
            layer: Layer tujuan (default: n_layers)
            mode: "all", "mlp", atau "attn"
            apply_ln: Apakah apply LayerNorm
            incl_embeds: Sertakan embedding
            return_labels: Kembalikan label komponen
        
        Returns:
            Stack komponen residual [n_components, batch, pos, d_model]
        """
        if layer is None:
            layer = self.n_layers
        
        incl_attn = mode != "mlp"
        incl_mlp = mode != "attn"
        
        components = []
        labels = []
        
        if incl_embeds:
            if self.has_embed and "hook_embed" in self._cache:
                components.append(self._cache["hook_embed"])
                labels.append("embed")
            if self.has_pos_embed and "hook_pos_embed" in self._cache:
                components.append(self._cache["hook_pos_embed"])
                labels.append("pos_embed")
        
        for l in range(layer):
            if incl_attn:
                key = f"blocks.{l}.hook_attn_out"
                if key in self._cache:
                    components.append(self._cache[key])
                    labels.append(f"{l}_attn_out")
            if incl_mlp:
                key = f"blocks.{l}.hook_mlp_out"
                if key in self._cache:
                    components.append(self._cache[key])
                    labels.append(f"{l}_mlp_out")
        
        if not components:
            raise ValueError("No components found in cache")
        
        result = np.stack(components, axis=0)
        
        if return_labels:
            return result, labels
        return result
    
    def accumulated_resid(
        self,
        layer: int = None,
        apply_ln: bool = False,
        return_labels: bool = False
    ) -> Union[np.ndarray, Tuple[np.ndarray, List[str]]]:
        """
        Akumulasi residual stream di setiap layer (Logit Lens).
        Porting dari ActivationCache.accumulated_resid.
        
        Returns:
            Stack akumulasi residual [n_layers+1, batch, pos, d_model]
        """
        if layer is None:
            layer = self.n_layers
        
        accum = []
        labels = []
        
        # Embedding
        resid = np.zeros_like(self._cache.get("hook_embed", np.zeros(1)))
        if self.has_embed and "hook_embed" in self._cache:
            resid = resid + self._cache["hook_embed"]
        if self.has_pos_embed and "hook_pos_embed" in self._cache:
            resid = resid + self._cache["hook_pos_embed"]
        
        accum.append(resid.copy())
        labels.append("embed")
        
        for l in range(layer):
            # Attention output
            attn_key = f"blocks.{l}.hook_attn_out"
            if attn_key in self._cache:
                resid = resid + self._cache[attn_key]
            
            accum.append(resid.copy())
            labels.append(f"{l}_attn_out")
            
            # MLP output
            mlp_key = f"blocks.{l}.hook_mlp_out"
            if mlp_key in self._cache:
                resid = resid + self._cache[mlp_key]
                accum.append(resid.copy())
                labels.append(f"{l}_mlp_out")
        
        result = np.stack(accum, axis=0)
        
        if return_labels:
            return result, labels
        return result
    
    def logit_attrs(
        self,
        residual_stack: np.ndarray,
        tokens: Union[str, int, np.ndarray],
        incorrect_tokens: Union[str, int, np.ndarray] = None
    ) -> np.ndarray:
        """
        Hitung atribusi logit dari residual stack ke token tertentu.
        Porting dari ActivationCache.logit_attrs.
        
        Args:
            residual_stack: [n_components, batch, pos, d_model]
            tokens: Token yang ingin diatribusikan
            incorrect_tokens: Token pembanding (opsional)
        
        Returns:
            Atribusi logit [n_components, batch, pos]
        """
        # Dalam implementasi nyata, ini akan menggunakan unembedding matrix
        # Untuk adaptasi QND, kita berikan placeholder
        
        if self.model is not None and hasattr(self.model, 'W_U'):
            W_U = self.model.W_U
            
            # Hitung logit untuk setiap komponen
            logits = np.tensordot(residual_stack, W_U, axes=([-1], [0]))
            
            # Ambil logit untuk token yang diminta
            if isinstance(tokens, (str, int)):
                # Perlu mapping token ke indeks
                token_idx = tokens if isinstance(tokens, int) else 0
                result = logits[..., token_idx]
            else:
                result = logits
            
            if incorrect_tokens is not None:
                # Hitung selisih logit
                if isinstance(incorrect_tokens, int):
                    result = result - logits[..., incorrect_tokens]
            
            return result
        
        # Fallback: return placeholder
        return np.mean(residual_stack, axis=-1)
    
    def get_full_resid_decomposition(
        self,
        layer: int = None,
        return_labels: bool = False
    ) -> Union[np.ndarray, Tuple[np.ndarray, List[str]]]:
        """
        Dekomposisi penuh residual stream termasuk neuron MLP individual.
        Porting dari ActivationCache.get_full_resid_decomposition.
        
        Returns:
            Stack dekomposisi [n_components, batch, pos, d_model]
        """
        # Untuk implementasi penuh, perlu akses ke weights model
        # Untuk QND, kita gunakan decompose_resid sebagai fallback
        return self.decompose_resid(layer=layer, mode="all", return_labels=return_labels)


# =============================================================================
# MODUL 3: SVD INTERPRETER (dari SVDInterpreter.py)
# =============================================================================

class SVDInterpreter:
    """
    Dekomposisi Singular Value untuk matriks weights Transformer.
    Porting dari transformer_lens.SVDInterpreter.
    
    Digunakan untuk mendapatkan singular vectors dari:
    - OV matrix (Output-Value): per attention head
    - w_in matrix: input weights MLP
    - w_out matrix: output weights MLP
    """
    
    def __init__(self, model=None):
        """
        Args:
            model: Model yang memiliki weights (opsional untuk QND)
        """
        self.model = model
        self.params = {}
        if model and hasattr(model, 'named_parameters'):
            self.params = {name: param for name, param in model.named_parameters()}
    
    def get_singular_vectors(
        self,
        vector_type: str,
        layer_index: int,
        num_vectors: int = 10,
        head_index: int = None
    ) -> np.ndarray:
        """
        Dapatkan singular vectors untuk tipe vector tertentu.
        
        Args:
            vector_type: "OV", "w_in", atau "w_out"
            layer_index: Indeks layer
            num_vectors: Jumlah vectors yang diinginkan
            head_index: Indeks head (hanya untuk OV)
        
        Returns:
            Singular vectors [num_vectors, d_model]
        """
        if self.model is None:
            # Placeholder untuk QND
            d_model = 4096  # Default
            return np.random.randn(num_vectors, d_model)
        
        # Untuk implementasi nyata dengan HookedTransformer:
        if vector_type == "OV" and head_index is not None:
            # Ekstrak OV matrix untuk head tertentu
            W_O = self._get_weight(f"blocks.{layer_index}.attn.W_O")
            W_V = self._get_weight(f"blocks.{layer_index}.attn.W_V")
            
            if W_O is not None and W_V is not None:
                n_heads = W_O.shape[0] if len(W_O.shape) > 2 else 1
                d_head = W_O.shape[-1] if len(W_O.shape) > 2 else W_O.shape[0]
                
                # Ekstrak head spesifik
                W_O_head = W_O[head_index] if len(W_O.shape) > 2 else W_O
                W_V_head = W_V[head_index] if len(W_V.shape) > 2 else W_V
                
                # OV = W_V @ W_O
                OV = W_V_head @ W_O_head.T if len(W_O_head.shape) == 2 else W_V_head @ W_O_head
                
                # SVD
                U, S, Vh = np.linalg.svd(OV, full_matrices=False)
                return Vh[:num_vectors]
        
        elif vector_type == "w_in":
            W_in = self._get_weight(f"blocks.{layer_index}.mlp.W_in")
            if W_in is not None:
                U, S, Vh = np.linalg.svd(W_in, full_matrices=False)
                return Vh[:num_vectors]
        
        elif vector_type == "w_out":
            W_out = self._get_weight(f"blocks.{layer_index}.mlp.W_out")
            if W_out is not None:
                U, S, Vh = np.linalg.svd(W_out, full_matrices=False)
                return U[:, :num_vectors].T
        
        # Fallback
        return np.random.randn(num_vectors, 4096)
    
    def _get_weight(self, name: str) -> Optional[np.ndarray]:
        """Ambil weight dari model berdasarkan nama."""
        if name in self.params:
            param = self.params[name]
            if hasattr(param, 'detach'):
                return param.detach().cpu().numpy()
            return np.array(param)
        return None
    
    def analyze_layer(
        self,
        layer_index: int,
        num_vectors: int = 10
    ) -> Dict[str, np.ndarray]:
        """
        Analisis lengkap satu layer: OV, w_in, w_out.
        
        Returns:
            Dictionary dengan singular vectors untuk setiap tipe
        """
        results = {}
        
        # OV per head (jika ada head_index)
        n_heads = 32  # Default, bisa disesuaikan
        all_ov = []
        for h in range(min(n_heads, 8)):  # Batasi 8 head pertama
            ov = self.get_singular_vectors("OV", layer_index, num_vectors, head_index=h)
            all_ov.append(ov)
        results["OV"] = np.stack(all_ov, axis=0) if all_ov else None
        
        # w_in
        results["w_in"] = self.get_singular_vectors("w_in", layer_index, num_vectors)
        
        # w_out
        results["w_out"] = self.get_singular_vectors("w_out", layer_index, num_vectors)
        
        return results


# =============================================================================
# MODUL 4: HEAD DETECTOR (dari head_detector.py)
# =============================================================================

class HeadDetector:
    """
    Deteksi attention head yang spesialis untuk tugas tertentu.
    Porting dari transformer_lens.head_detector.
    
    Jenis head yang bisa dideteksi:
    - previous_token_head: Head yang selalu attend ke token sebelumnya
    - duplicate_token_head: Head yang selalu attend ke token yang sama
    - induction_head: Head yang melakukan induksi pola [A][B] -> [A] -> [B]
    """
    
    # Pola deteksi untuk berbagai jenis head
    DETECTION_PATTERNS = {
        "previous_token_head": "previous",
        "duplicate_token_head": "duplicate",
        "induction_head": "induction",
    }
    
    def __init__(self, model=None):
        self.model = model
    
    def create_detection_pattern(
        self,
        head_type: str,
        seq_len: int
    ) -> np.ndarray:
        """
        Buat pola deteksi untuk jenis head tertentu.
        
        Args:
            head_type: "previous_token_head", "duplicate_token_head", atau "induction_head"
            seq_len: Panjang sekuens
        
        Returns:
            Pola deteksi [seq_len, seq_len]
        """
        pattern = np.zeros((seq_len, seq_len))
        
        if head_type == "previous_token_head":
            # Attend ke token sebelumnya (satu posisi di atas diagonal)
            for i in range(1, seq_len):
                pattern[i, i-1] = 1.0
        
        elif head_type == "duplicate_token_head":
            # Attend ke token yang sama (diagonal)
            for i in range(seq_len):
                pattern[i, i] = 1.0
        
        elif head_type == "induction_head":
            # Pola induksi: attend ke token setelah kemunculan sebelumnya
            # Contoh: [A][B]...[A] -> attend ke [B]
            for i in range(1, seq_len):
                pattern[i, 0] = 0.5  # Simplifikasi
                if i > 1:
                    pattern[i, 1] = 0.5
        
        return pattern
    
    def detect_head(
        self,
        attention_pattern: np.ndarray,
        head_type: str,
        error_measure: str = "mul"
    ) -> float:
        """
        Deteksi apakah attention pattern cocok dengan jenis head tertentu.
        
        Args:
            attention_pattern: [seq_len, seq_len] atau [n_heads, seq_len, seq_len]
            head_type: Jenis head yang dicari
            error_measure: "mul" atau "abs"
        
        Returns:
            Skor kecocokan (0-1, semakin tinggi semakin cocok)
        """
        if len(attention_pattern.shape) == 3:
            # Multiple heads: rata-rata skor
            scores = []
            for h in range(attention_pattern.shape[0]):
                scores.append(self._detect_single_head(attention_pattern[h], head_type, error_measure))
            return np.mean(scores)
        
        return self._detect_single_head(attention_pattern, head_type, error_measure)
    
    def _detect_single_head(
        self,
        attention: np.ndarray,
        head_type: str,
        error_measure: str
    ) -> float:
        """Deteksi satu head."""
        seq_len = attention.shape[0]
        detection = self.create_detection_pattern(head_type, seq_len)
        
        # Pastikan attention adalah lower triangular (causal)
        mask = np.tril(np.ones((seq_len, seq_len)))
        attention = attention * mask
        
        # Normalisasi attention
        row_sums = attention.sum(axis=-1, keepdims=True)
        row_sums = np.where(row_sums > 0, row_sums, 1.0)
        attention = attention / row_sums
        
        if error_measure == "mul":
            # Multiply element-wise
            score = np.sum(attention * detection) / max(np.sum(attention), 1e-8)
        elif error_measure == "abs":
            # Mean absolute difference
            diff = np.abs(attention - detection)
            score = 1.0 - np.mean(diff) / 2.0
        else:
            raise ValueError(f"Unknown error measure: {error_measure}")
        
        return float(np.clip(score, 0.0, 1.0))
    
    def analyze_all_heads(
        self,
        attention_patterns: Dict[int, np.ndarray],
        head_type: str = "previous_token_head"
    ) -> Dict[int, Dict[int, float]]:
        """
        Analisis semua head di semua layer.
        
        Args:
            attention_patterns: {layer: attention_matrix[n_heads, seq, seq]}
            head_type: Jenis head yang dicari
        
        Returns:
            {layer: {head_index: score}}
        """
        results = {}
        for layer, attn in attention_patterns.items():
            layer_results = {}
            for h in range(attn.shape[0]):
                score = self.detect_head(attn[h], head_type)
                layer_results[h] = score
            results[layer] = layer_results
        return results


# =============================================================================
# MODUL 5: LOGIT LENS (teknik dari ActivationCache.accumulated_resid)
# =============================================================================

class LogitLens:
    """
    Logit Lens: Melihat prediksi token di setiap layer model.
    Teknik dari TransformerLens, bukan kelas terpisah.
    
    Cara kerja:
    1. Ambil akumulasi residual stream di setiap layer
    2. Apply final layer norm
    3. Kalikan dengan unembedding matrix (W_U)
    4. Lihat token apa yang diprediksi di setiap layer
    """
    
    def __init__(self, model=None, unembedding_matrix: np.ndarray = None):
        """
        Args:
            model: Model dengan W_U (unembedding matrix)
            unembedding_matrix: Unembedding matrix langsung [d_model, vocab_size]
        """
        self.model = model
        self.W_U = unembedding_matrix
        
        if model and hasattr(model, 'W_U'):
            self.W_U = model.W_U
        elif model and hasattr(model, 'unembed'):
            self.W_U = model.unembed.W if hasattr(model.unembed, 'W') else None
    
    def project_to_vocab(
        self,
        residual_stream: np.ndarray,
        apply_ln: bool = True
    ) -> np.ndarray:
        """
        Proyeksikan residual stream ke ruang vocabulary.
        
        Args:
            residual_stream: [..., d_model]
            apply_ln: Apakah apply LayerNorm dulu
        
        Returns:
            Logits [... , vocab_size]
        """
        if self.W_U is None:
            raise ValueError("Unembedding matrix (W_U) not available")
        
        # Apply LayerNorm (simplifikasi: norm = x / std)
        if apply_ln:
            std = np.std(residual_stream, axis=-1, keepdims=True)
            std = np.where(std > 0, std, 1.0)
            normalized = residual_stream / std
        else:
            normalized = residual_stream
        
        # Proyeksi ke vocab
        if len(normalized.shape) == 1:
            logits = normalized @ self.W_U
        elif len(normalized.shape) == 2:
            logits = normalized @ self.W_U
        else:
            logits = np.tensordot(normalized, self.W_U, axes=([-1], [0]))
        
        return logits
    
    def get_top_tokens(
        self,
        logits: np.ndarray,
        k: int = 5,
        token_decoder: Callable = None
    ) -> List[Union[int, str]]:
        """
        Dapatkan top-k token dari logits.
        
        Args:
            logits: [..., vocab_size]
            k: Jumlah token yang diinginkan
            token_decoder: Fungsi untuk decode token ID ke string
        
        Returns:
            List token (ID atau string)
        """
        top_indices = np.argsort(logits, axis=-1)[..., -k:][..., ::-1]
        
        if token_decoder is not None:
            # Decode token IDs ke strings
            decoded = []
            for idx in np.nditer(top_indices):
                decoded.append(token_decoder(int(idx)))
            return decoded
        
        return top_indices.tolist()
    
    def analyze_layer_predictions(
        self,
        activation_cache: ActivationCache,
        k: int = 5
    ) -> Dict[str, List]:
        """
        Analisis prediksi di setiap layer menggunakan Logit Lens.
        
        Args:
            activation_cache: Cache aktivasi dari run_with_cache
            k: Jumlah top token per layer
        
        Returns:
            {layer_label: top_tokens}
        """
        accum, labels = activation_cache.accumulated_resid(return_labels=True)
        
        results = {}
        for i, label in enumerate(labels):
            resid = accum[i]
            logits = self.project_to_vocab(resid)
            top = self.get_top_tokens(logits[..., -1, :], k=k)  # Token terakhir
            results[label] = top
        
        return results


# =============================================================================
# MODUL 6: HOOKED TRANSFORMER (struktur dasar dari HookedTransformer.py)
# =============================================================================

class HookedTransformerConfig:
    """
    Konfigurasi untuk HookedTransformer.
    Porting dari transformer_lens.HookedTransformerConfig.
    """
    
    def __init__(
        self,
        n_layers: int = 12,
        n_heads: int = 12,
        d_model: int = 768,
        d_head: int = 64,
        d_vocab: int = 50257,
        d_mlp: int = 3072,
        n_ctx: int = 1024,
        act_fn: str = "gelu",
        normalization_type: str = "LN",
        use_attn_scale: bool = True,
        use_local_attn: bool = False,
        use_hook_tokens: bool = True,
        use_split_qkv_input: bool = False,
        use_hook_mlp_in: bool = False,
        default_prepend_bos: bool = True,
        position_embedding_type: str = "standard",
        **kwargs
    ):
        self.n_layers = n_layers
        self.n_heads = n_heads
        self.d_model = d_model
        self.d_head = d_head
        self.d_vocab = d_vocab
        self.d_mlp = d_mlp
        self.n_ctx = n_ctx
        self.act_fn = act_fn
        self.normalization_type = normalization_type
        self.use_attn_scale = use_attn_scale
        self.use_local_attn = use_local_attn
        self.use_hook_tokens = use_hook_tokens
        self.use_split_qkv_input = use_split_qkv_input
        self.use_hook_mlp_in = use_hook_mlp_in
        self.default_prepend_bos = default_prepend_bos
        self.position_embedding_type = position_embedding_type
        
        for k, v in kwargs.items():
            setattr(self, k, v)
    
    @classmethod
    def from_dict(cls, config_dict: Dict) -> 'HookedTransformerConfig':
        """Buat konfigurasi dari dictionary (seperti metadata GGUF)."""
        return cls(**config_dict)


class HookedTransformer:
    """
    Model Transformer yang sudah di-hook untuk interpretabilitas.
    Adaptasi minimal dari transformer_lens.HookedTransformer.
    
    Untuk QND DeepReader, ini berfungsi sebagai wrapper yang menyediakan
    akses ke weights model dan kemampuan untuk menjalankan inference
    dengan caching aktivasi.
    """
    
    def __init__(self, config: HookedTransformerConfig):
        self.cfg = config
        self.mod_dict = {}
        self.hook_dict = {}
        self.W_U = None  # Unembedding matrix
        self.W_E = None  # Embedding matrix
        self.blocks = []  # TransformerBlock list
    
    def setup_hooks(self):
        """Setup HookPoints untuk semua komponen model."""
        # Ini akan diimplementasikan sesuai arsitektur spesifik
        pass
    
    def run_with_cache(
        self,
        input_ids: np.ndarray,
        names_filter: Union[None, str, List[str], Callable] = None,
        remove_batch_dim: bool = False
    ) -> Tuple[np.ndarray, Dict[str, np.ndarray]]:
        """
        Jalankan model dan kembalikan output + cache.
        
        Args:
            input_ids: Token IDs [batch, seq_len]
            names_filter: Filter untuk aktivasi yang di-cache
        
        Returns:
            (logits, cache_dict)
        """
        cache = {}
        # Implementasi forward pass dengan hooks
        # Ini akan diisi dengan logika forward pass yang sesuai
        logits = np.random.randn(input_ids.shape[0], input_ids.shape[1], self.cfg.d_vocab)
        return logits, cache
    
    def forward(self, input_ids: np.ndarray) -> np.ndarray:
        """Forward pass sederhana."""
        logits, _ = self.run_with_cache(input_ids)
        return logits


